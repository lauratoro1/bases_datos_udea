        <mxCell id="KZrusXF22_Iq3ZgwrWtc-72" parent="1" style="shape=rhombus;perimeter=rhombusPerimeter;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" value="OPERA_EN" vertex="1">
          <mxGeometry height="60" width="100" x="1644" y="599" as="geometry" />
        </mxCell>
        <mxCell id="KZrusXF22_Iq3ZgwrWtc-73" edge="1" parent="1" source="KZrusXF22_Iq3ZgwrWtc-9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;" target="KZrusXF22_Iq3ZgwrWtc-72">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="KZrusXF22_Iq3ZgwrWtc-74" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=12;fontStyle=0;" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;1:N&lt;/font&gt;" vertex="1">
          <mxGeometry height="20" width="30" x="864" y="659" as="geometry" />
        </mxCell>
        <mxCell id="KZrusXF22_Iq3ZgwrWtc-75" parent="1" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=5;spacingTop=5;" value="&lt;b&gt;REGLAS DE NEGOCIO&lt;/b&gt;&lt;hr&gt;&lt;b&gt;1.&lt;/b&gt; Pasajero - Tiquete: Un pasajero puede comprar muchos tiquetes (0..N), un tiquete pertenece a un pasajero (1). &lt;b&gt;Cardinalidad: 1:N&lt;/b&gt;&lt;br&gt;&lt;b&gt;2.&lt;/b&gt; Conductor - Bus: Un conductor puede conducir muchos buses (0..N), un bus es conducido por un conductor (1). &lt;b&gt;Cardinalidad: 1:N&lt;/b&gt;&lt;br&gt;&lt;b&gt;3.&lt;/b&gt; Bus - Viaje: Un bus puede asignarse a muchos viajes (0..N), un viaje tiene un bus asignado (1). &lt;b&gt;Cardinalidad: 1:N&lt;/b&gt;&lt;br&gt;&lt;b&gt;4.&lt;/b&gt; Ruta - Viaje: Una ruta puede ser seguida por muchos viajes (0..N), un viaje sigue una ruta (1). &lt;b&gt;Cardinalidad: 1:N&lt;/b&gt;&lt;br&gt;&lt;b&gt;5.&lt;/b&gt; Terminal - Viaje: Un viaje tiene origen (1) y destino (1). Un terminal puede ser origen/destino de muchos viajes (0..N). &lt;b&gt;Cardinalidad: 1:N&lt;/b&gt;&lt;br&gt;&lt;b&gt;6.&lt;/b&gt; Tiquete - Viaje: Un tiquete es para un viaje (1), un viaje puede tener muchos tiquetes (0..N). &lt;b&gt;Cardinalidad: 1:N&lt;/b&gt;&lt;br&gt;&lt;b&gt;7.&lt;/b&gt; Todos los viajes deben tener conductor, bus, ruta y pasajeros asignados (obligatoriedad).&lt;br&gt;&lt;b&gt;8.&lt;/b&gt; Relación M:N entre PASAJERO y VIAJE está resuelta mediante la entidad TIQUETE.&lt;br&gt;&lt;b&gt;9.&lt;/b&gt; El número de documento del pasajero, la licencia del conductor y la placa del bus son únicos en el sistema." vertex="1">
          <mxGeometry height="170" width="720" x="936" y="1692" as="geometry" />
        </mxCell>
        <mxCell id="KZrusXF22_Iq3ZgwrWtc-76" parent="1" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontStyle=1;" value="RELACIÓN M:N RESUELTA&lt;br&gt;PASAJERO ↔ VIAJE&lt;br&gt;a través de TIQUETE" vertex="1">
          <mxGeometry height="50" width="140" x="1140" y="324" as="geometry" />
        </mxCell>
